generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["kunde"]
}

model Adresse {
  id         Int    @id @default(autoincrement())
  strasse    String
  hausnummer String
  plz        String
  ort        String

  kundeId Int   @unique @map("kunde_id")
  kunde   Kunde @relation(fields: [kundeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("adresse")
  @@schema("kunde")
}

model Bestellung {
  id          Int    @id @default(autoincrement())
  produktname String
  menge       Int

  kundeId Int   @map("kunde_id")
  kunde   Kunde @relation(fields: [kundeId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("bestellung")
  @@schema("kunde")
}

model Kunde {
  id       Int     @id @default(autoincrement())
  nachname String
  email    String  @unique
  username String? @unique
  version  Int     @default(0)

  adresse      Adresse?
  bestellungen Bestellung[]

  @@map("kunde")
  @@schema("kunde")
}
